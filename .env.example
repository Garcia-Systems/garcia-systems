# Garcia Systems environment template
# Copy this file to .env for local development. Deployment platforms such as
# Laravel Cloud should define the same variables in their environment settings.
# Never commit real secrets or production credentials.

# -----------------------------------------------------------------------------
# Required application variables
# -----------------------------------------------------------------------------
APP_NAME="Garcia Systems"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Required for production. Use "php artisan key:generate --show" to generate
# APP_KEY, and keep APP_PREVIOUS_KEYS only during key rotation.
APP_PREVIOUS_KEYS=

# -----------------------------------------------------------------------------
# Optional maintenance and logging variables
# -----------------------------------------------------------------------------
APP_MAINTENANCE_DRIVER=file
# Production-only: use "database" when maintenance mode must be shared by
# multiple application servers.
APP_MAINTENANCE_STORE=database

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_DEPRECATIONS_TRACE=false
LOG_LEVEL=info
LOG_DAILY_DAYS=14
# Optional production logging integrations.
LOG_SLACK_WEBHOOK_URL=
LOG_SLACK_USERNAME="Garcia Systems"
LOG_SLACK_EMOJI=:boom:
LOG_PAPERTRAIL_HANDLER=
PAPERTRAIL_URL=
PAPERTRAIL_PORT=
LOG_STDERR_FORMATTER=
LOG_SYSLOG_FACILITY=

# -----------------------------------------------------------------------------
# Required database variables
# -----------------------------------------------------------------------------
# Production recommendation: use a managed MySQL or PostgreSQL database.
# Laravel Cloud may provide DB_URL instead of individual DB_* values.
DB_CONNECTION=mysql
DB_URL=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=garcia_systems
DB_USERNAME=garcia_systems
DB_PASSWORD=
DB_SOCKET=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_FOREIGN_KEYS=true
# Optional production-only database TLS setting for MySQL/MariaDB.
MYSQL_ATTR_SSL_CA=
# Optional PostgreSQL-only setting.
DB_SSLMODE=prefer

# Development-only SQLite example:
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database/database.sqlite

# -----------------------------------------------------------------------------
# Required cache, queue, session, and filesystem variables
# -----------------------------------------------------------------------------
CACHE_STORE=database
CACHE_PREFIX=
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids
FILESYSTEM_DISK=local

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_CONNECTION=
SESSION_TABLE=sessions
SESSION_STORE=
SESSION_COOKIE=
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false

# Database-backed cache and queue options. Leave blank to use the default DB
# connection and Laravel's default table names.
DB_CACHE_CONNECTION=
DB_CACHE_TABLE=cache
DB_CACHE_LOCK_CONNECTION=
DB_CACHE_LOCK_TABLE=
DB_QUEUE_CONNECTION=
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=90

# Optional file-cache settings when CACHE_STORE=file.
CACHE_STORAGE_DISK=
CACHE_STORAGE_PATH=framework/cache/data

# -----------------------------------------------------------------------------
# Required mail and lead notification variables
# -----------------------------------------------------------------------------
# Development can keep MAIL_MAILER=log. Production should use a real mailer
# such as smtp, ses, postmark, or resend and provide that provider's credentials.
MAIL_MAILER=log
MAIL_SCHEME=
MAIL_URL=
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_EHLO_DOMAIN=
MAIL_SENDMAIL_PATH="/usr/sbin/sendmail -bs -i"
MAIL_LOG_CHANNEL=
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"
LEAD_NOTIFICATION_EMAIL=leads@example.com

# Optional mail providers. Required only when MAIL_MAILER uses the provider.
POSTMARK_API_KEY=
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Optional administrator bootstrap variables
# -----------------------------------------------------------------------------
# Required only when intentionally running AdministratorSeeder to create the
# first administrator account. Use a strong password managed outside git.
ADMIN_NAME="Garcia Systems Admin"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Optional Redis, Memcached, AWS, SQS, Beanstalkd, DynamoDB, and Slack variables
# -----------------------------------------------------------------------------
# Required only when selecting the corresponding cache, queue, filesystem, mail,
# logging, or notification driver.
REDIS_CLIENT=phpredis
REDIS_CLUSTER=redis
REDIS_PREFIX=
REDIS_PERSISTENT=false
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_MAX_RETRIES=3
REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
REDIS_BACKOFF_BASE=100
REDIS_BACKOFF_CAP=1000
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90

MEMCACHED_PERSISTENT_ID=
MEMCACHED_USERNAME=
MEMCACHED_PASSWORD=
MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

SQS_PREFIX=https://sqs.us-east-1.amazonaws.com/your-account-id
SQS_QUEUE=default
SQS_SUFFIX=

BEANSTALKD_QUEUE_HOST=localhost
BEANSTALKD_QUEUE=default
BEANSTALKD_QUEUE_RETRY_AFTER=90

DYNAMODB_CACHE_TABLE=cache
DYNAMODB_ENDPOINT=

SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

# -----------------------------------------------------------------------------
# Optional authentication overrides
# -----------------------------------------------------------------------------
AUTH_GUARD=web
AUTH_PASSWORD_BROKER=users
AUTH_MODEL=App\Models\User
AUTH_PASSWORD_RESET_TOKEN_TABLE=password_reset_tokens
AUTH_PASSWORD_TIMEOUT=10800

# -----------------------------------------------------------------------------
# Development-only Laravel Sail variables
# -----------------------------------------------------------------------------
# APP_PORT=80
# VITE_PORT=5173
# FORWARD_DB_PORT=3306
# FORWARD_REDIS_PORT=6379
# PHP_CLI_SERVER_WORKERS=4
