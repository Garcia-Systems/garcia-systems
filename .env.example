# Garcia Systems environment template
# Copy this file to .env for local development or Laravel Sail.
# Deployment platforms such as Laravel Cloud should define production values in
# their environment settings. Never commit real secrets or production credentials.

# -----------------------------------------------------------------------------
# Required application variables (local defaults are safe for CI and Sail)
# -----------------------------------------------------------------------------
APP_NAME="Garcia Systems"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Production overrides required before deploy:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-production-domain.example
# Generate APP_KEY with: php artisan key:generate --show
# APP_PREVIOUS_KEYS=

# -----------------------------------------------------------------------------
# Optional maintenance and logging variables
# -----------------------------------------------------------------------------
APP_MAINTENANCE_DRIVER=file
# Production-only: use "database" when maintenance mode must be shared by
# multiple application servers.
# APP_MAINTENANCE_STORE=database

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Optional logging overrides/integrations:
# LOG_DEPRECATIONS_TRACE=false
# LOG_DAILY_DAYS=14
# LOG_SLACK_WEBHOOK_URL=
# LOG_SLACK_USERNAME="Garcia Systems"
# LOG_SLACK_EMOJI=:boom:
# LOG_PAPERTRAIL_HANDLER=
# PAPERTRAIL_URL=
# PAPERTRAIL_PORT=
# LOG_STDERR_FORMATTER=
# LOG_SYSLOG_FACILITY=

# -----------------------------------------------------------------------------
# Database variables (local/CI-safe defaults)
# -----------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Optional database settings used by Laravel config:
# DB_URL=
# DB_SOCKET=
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci
# DB_FOREIGN_KEYS=true
# MYSQL_ATTR_SSL_CA=
# DB_SSLMODE=prefer

# Production database example: set DB_CONNECTION to mysql or pgsql, then provide
# DB_HOST, DB_PORT, DB_DATABASE, DB_USERNAME, and DB_PASSWORD from your managed
# database provider. Use DB_URL instead when your deployment platform provides it.

# -----------------------------------------------------------------------------
# Cache, queue, session, and filesystem variables
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Production session overrides recommended for HTTPS deployments:
# SESSION_SECURE_COOKIE=true
# SESSION_HTTP_ONLY=true
# SESSION_SAME_SITE=lax
# SESSION_EXPIRE_ON_CLOSE=false
# SESSION_CONNECTION=
# SESSION_TABLE=sessions
# SESSION_STORE=
# SESSION_COOKIE=
# SESSION_PARTITIONED_COOKIE=false

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

# Database-backed cache and queue options. Leave commented to use the default DB
# connection and Laravel's default table names.
# DB_CACHE_CONNECTION=
# DB_CACHE_TABLE=cache
# DB_CACHE_LOCK_CONNECTION=
# DB_CACHE_LOCK_TABLE=
# DB_QUEUE_CONNECTION=
# DB_QUEUE_TABLE=jobs
# DB_QUEUE=default
# DB_QUEUE_RETRY_AFTER=90
# QUEUE_FAILED_DRIVER=database-uuids

# Optional file-cache settings when CACHE_STORE=file.
# CACHE_STORAGE_DISK=
# CACHE_STORAGE_PATH=framework/cache/data

# -----------------------------------------------------------------------------
# Mail and lead notification variables
# -----------------------------------------------------------------------------
# Development can keep MAIL_MAILER=log. Production should use a real mailer
# such as smtp, ses, postmark, or resend and provide that provider's credentials.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
LEAD_NOTIFICATION_EMAIL=leads@example.com

# Optional mail settings/providers. Required only when MAIL_MAILER uses them.
# MAIL_URL=
# MAIL_EHLO_DOMAIN=
# MAIL_SENDMAIL_PATH="/usr/sbin/sendmail -bs -i"
# MAIL_LOG_CHANNEL=
# POSTMARK_API_KEY=
# RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Optional administrator bootstrap variables
# -----------------------------------------------------------------------------
# Required only when intentionally running AdministratorSeeder to create the
# first administrator account. Use real values in .env or the deployment
# platform; do not commit production credentials.
ADMIN_NAME="Garcia Systems Admin"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Optional Redis and Memcached variables
# -----------------------------------------------------------------------------
# Required only when selecting the corresponding cache, queue, or session driver.
MEMCACHED_HOST=127.0.0.1
# MEMCACHED_PERSISTENT_ID=
# MEMCACHED_USERNAME=
# MEMCACHED_PASSWORD=
# MEMCACHED_PORT=11211

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# REDIS_CLUSTER=redis
# REDIS_PREFIX=
# REDIS_PERSISTENT=false
# REDIS_URL=
# REDIS_USERNAME=
# REDIS_DB=0
# REDIS_CACHE_DB=1
# REDIS_MAX_RETRIES=3
# REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
# REDIS_BACKOFF_BASE=100
# REDIS_BACKOFF_CAP=1000
# REDIS_CACHE_CONNECTION=cache
# REDIS_CACHE_LOCK_CONNECTION=default
# REDIS_QUEUE_CONNECTION=default
# REDIS_QUEUE=default
# REDIS_QUEUE_RETRY_AFTER=90

# -----------------------------------------------------------------------------
# Optional AWS, SQS, Beanstalkd, DynamoDB, and Slack variables
# -----------------------------------------------------------------------------
# Required only when selecting the corresponding filesystem, cache, queue, mail,
# logging, or notification driver.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# AWS_URL=
# AWS_ENDPOINT=
# SQS_PREFIX=https://sqs.us-east-1.amazonaws.com/your-account-id
# SQS_QUEUE=default
# SQS_SUFFIX=
# BEANSTALKD_QUEUE_HOST=localhost
# BEANSTALKD_QUEUE=default
# BEANSTALKD_QUEUE_RETRY_AFTER=90
# DYNAMODB_CACHE_TABLE=cache
# DYNAMODB_ENDPOINT=
# SLACK_BOT_USER_OAUTH_TOKEN=
# SLACK_BOT_USER_DEFAULT_CHANNEL=

# -----------------------------------------------------------------------------
# Optional authentication overrides
# -----------------------------------------------------------------------------
# AUTH_GUARD=web
# AUTH_PASSWORD_BROKER=users
# AUTH_MODEL=App\Models\User
# AUTH_PASSWORD_RESET_TOKEN_TABLE=password_reset_tokens
# AUTH_PASSWORD_TIMEOUT=10800

# -----------------------------------------------------------------------------
# Development-only Laravel Sail variables
# -----------------------------------------------------------------------------
# APP_PORT=80
# VITE_PORT=5173
# FORWARD_DB_PORT=3306
# FORWARD_REDIS_PORT=6379
# PHP_CLI_SERVER_WORKERS=4

# -----------------------------------------------------------------------------
# Frontend variable examples
# -----------------------------------------------------------------------------
# VITE_APP_NAME="${APP_NAME}"
